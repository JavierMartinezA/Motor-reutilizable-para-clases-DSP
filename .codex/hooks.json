{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const cmd=process.env.CLAUDE_TOOL_INPUT_command||'';if(/dsp_pipelines[\\\\/](pipelines|.*\\.py)/.test(cmd)||/python\\s+.*dsp_pipelines/.test(cmd)){const cp=require('child_process');try{cp.execSync('python sync_to_public.py',{stdio:'inherit',timeout:120000});}catch(e){process.exit(0);}}\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const p=process.env.CLAUDE_TOOL_INPUT_file_path||'';if(/dsp_pipelines[\\\\/](outputs|pipelines)/.test(p)){const cp=require('child_process');try{cp.execSync('python sync_to_public.py',{stdio:'inherit',timeout:120000});}catch(e){process.exit(0);}}\""
          }
        ]
      }
    ]
  }
}
