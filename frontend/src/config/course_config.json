{
  "$schema": "./course_config.schema.json",
  "course": {
    "title": "Agente Autónomo de Diseño Paramétrico de Sonido",
    "shortTitle": "Hito 2",
    "subtitle": "Síntesis FM y Descriptores MIR · IEE3736-1",
    "institution": "Pontificia Universidad Católica de Chile",
    "term": "Hito 2"
  },
  "theme": {
    "background": "cream",
    "accent": "#2563eb",
    "showHeaderTitle": true,
    "showProgressDots": true,
    "showSlideCounter": true
  },
  "slides": [
    {
      "id": "pivote_proyecto",
      "label": "01 · Pivote del proyecto",
      "props": {}
    },
    {
      "id": "sound_matching_fm",
      "label": "02 · Sound matching en FM",
      "props": {}
    },
    {
      "id": "rl_mdp",
      "label": "03 · RL como solución + MDP",
      "props": {}
    },
    {
      "id": "implementacion_prototipo",
      "label": "04 · Implementación del prototipo",
      "props": {}
    },
    {
      "id": "resultados",
      "label": "05 · Resultados",
      "props": {}
    },
    {
      "id": "conclusiones",
      "label": "06 · Conclusiones y próximos pasos",
      "props": {}
    }
  ],
  "pipelines": {
    "recreando_80s": {
      "module": "recreando_80s",
      "input": "original_80s.wav",
      "params": {
        "sr": 44100,
        "duration_s": 1.4,
        "fc": 73.4,
        "ratio": 1.0,
        "I_max": 6.5,
        "detune_hz": 0.5,
        "master_dbfs": -1.4,
        "attack_s": 0.005,
        "decay_s": 0.35,
        "sustain": 0.55,
        "release_s": 0.6,
        "fmax_view_hz": 3000
      },
      "outputs": {
        "audio": {
          "cover_80s.wav": "cover_80s.wav",
          "cover_80s_melody.wav": "cover_80s_melody.wav",
          "original_80s.wav": "original_80s.wav"
        },
        "images": {
          "recreando_80s_spec_original.png": "recreando_80s_spec_original.png",
          "recreando_80s_spec_cover.png": "recreando_80s_spec_cover.png",
          "recreando_80s_spec_compare.png": "recreando_80s_spec_compare.png"
        }
      }
    },
    "sintesis_clasica": {
      "module": "sintesis_clasica",
      "input": "dummy_silence.wav",
      "params": {
        "sr": 44100,
        "duration_s": 2.5,
        "f0": 220,
        "n_harmonics": 8,
        "wavetable_size": 2048,
        "cutoff_hz": 1800,
        "filter_order": 4
      },
      "outputs": {
        "audio": {
          "sintesis_clasica_aditiva.wav": "sintesis_clasica_aditiva.wav",
          "sintesis_clasica_wavetable.wav": "sintesis_clasica_wavetable.wav",
          "sintesis_clasica_sustractiva.wav": "sintesis_clasica_sustractiva.wav"
        },
        "images": {
          "sintesis_clasica_harmonics.png": "sintesis_clasica_harmonics.png",
          "sintesis_clasica_filter.png": "sintesis_clasica_filter.png"
        }
      }
    }
  },
  "_doc": {
    "slides[]": {
      "id": "string · clave única; debe coincidir con la entrada en src/slides/index.js y con el ## anchor en content.md",
      "label": "string · texto mostrado en tooltips/dots",
      "props": "object opcional · pasado como props al componente (audio, imágenes, parámetros)"
    },
    "pipelines.<id>": {
      "module": "string · nombre del módulo en dsp_pipelines/pipelines/",
      "input": "string · archivo en dsp_pipelines/inputs/",
      "params": "object · kwargs serializables pasados a run()",
      "outputs": {
        "audio": "object · { logical_name: 'archivo_destino_en_public.wav' }",
        "images": "object · { logical_name: 'archivo_destino_en_public.png' }"
      }
    }
  }
}
