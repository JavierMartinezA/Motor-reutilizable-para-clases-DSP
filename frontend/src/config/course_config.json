{
  "$schema": "./course_config.schema.json",
  "defaultDeck": "mir",
  "decks": {
    "fm": {
      "course": {
        "title": "Síntesis FM",
        "shortTitle": "Sesión 09",
        "subtitle": "Modulación de Frecuencia · IEE3736-1",
        "institution": "Pontificia Universidad Católica de Chile",
        "term": "Sesión 09"
      },
      "theme": {
        "background": "cream",
        "accent": "#2563eb",
        "showHeaderTitle": true,
        "showProgressDots": true,
        "showSlideCounter": true
      },
      "slides": [
        { "id": "sintesis_fm", "label": "01 · Portada y el DX7", "props": {} },
        { "id": "fm_intuicion", "label": "02 · Vibrato → Timbre", "props": {} },
        { "id": "fm_ecuacion", "label": "03 · Ecuación y plano", "props": {} },
        { "id": "fm_bessel", "label": "04 · Bessel sin álgebra", "props": {} },
        { "id": "fm_vivo", "label": "05 · Plano FM en vivo", "props": {} },
        { "id": "recreando_80s", "label": "06 · Fun Task — Recreando los 80s", "props": {} },
        { "id": "fm_debate", "label": "07 · El vacío de Bessel", "props": {} }
      ]
    },
    "mir": {
      "course": {
        "title": "MIR & Audio Fingerprinting",
        "shortTitle": "Clase 11",
        "subtitle": "Music Information Retrieval y el algoritmo de Shazam · IEE3736-1",
        "institution": "Pontificia Universidad Católica de Chile",
        "term": "Clase 11"
      },
      "theme": {
        "background": "cream",
        "accent": "#7c3aed",
        "showHeaderTitle": true,
        "showProgressDots": true,
        "showSlideCounter": true
      },
      "slides": [
        { "id": "portada_mir", "label": "01 · Portada — MIR & Fingerprinting", "props": {} },
        { "id": "problema_shazam", "label": "02 · El misterio de Shazam", "props": {} },
        { "id": "shazam_teaser", "label": "03 · Demostración en vivo", "props": {} },
        { "id": "bifurcacion", "label": "04 · Dos tareas sobre el espectrograma", "props": {} },
        { "id": "features_audio", "label": "05 · DESCRIBIR — descriptores de audio", "props": {} },
        { "id": "onset_bpm", "label": "06 · Onsets & BPM", "props": {} },
        { "id": "grieta_describir", "label": "07 · El límite de los descriptores", "props": {} },
        { "id": "constelacion_wang", "label": "08 · La constelación de Wang", "props": {} },
        { "id": "hashing_combinatorio", "label": "09 · Hashing + índice invertido", "props": {} },
        { "id": "wang_coherencia", "label": "10 · Coherencia temporal (Wang)", "props": {} },
        { "id": "histograma_offsets", "label": "11 · Histograma de offsets", "props": {} },
        { "id": "shazam_pipeline", "label": "12 · Pipeline Completo", "props": {} }
      ]
    }
  },
  "pipelines": {
    "recreando_80s": {
      "module": "recreando_80s",
      "input": "original_80s.wav",
      "params": {
        "sr": 44100,
        "duration_s": 1.4,
        "fc": 73.4,
        "ratio": 1.0,
        "I_max": 6.5,
        "detune_hz": 0.5,
        "master_dbfs": -1.4,
        "attack_s": 0.005,
        "decay_s": 0.35,
        "sustain": 0.55,
        "release_s": 0.6,
        "fmax_view_hz": 3000
      },
      "outputs": {
        "audio": {
          "cover_80s.wav": "cover_80s.wav",
          "cover_80s_melody.wav": "cover_80s_melody.wav",
          "original_80s.wav": "original_80s.wav"
        },
        "images": {
          "recreando_80s_spec_original.png": "recreando_80s_spec_original.png",
          "recreando_80s_spec_cover.png": "recreando_80s_spec_cover.png",
          "recreando_80s_spec_compare.png": "recreando_80s_spec_compare.png"
        }
      }
    },
    "sintesis_clasica": {
      "module": "sintesis_clasica",
      "input": "dummy_silence.wav",
      "params": {
        "sr": 44100,
        "duration_s": 2.5,
        "f0": 220,
        "n_harmonics": 8,
        "wavetable_size": 2048,
        "cutoff_hz": 1800,
        "filter_order": 4
      },
      "outputs": {
        "audio": {
          "sintesis_clasica_aditiva.wav": "sintesis_clasica_aditiva.wav",
          "sintesis_clasica_wavetable.wav": "sintesis_clasica_wavetable.wav",
          "sintesis_clasica_sustractiva.wav": "sintesis_clasica_sustractiva.wav"
        },
        "images": {
          "sintesis_clasica_harmonics.png": "sintesis_clasica_harmonics.png",
          "sintesis_clasica_filter.png": "sintesis_clasica_filter.png"
        }
      }
    }
  },
  "_doc": {
    "defaultDeck": "string · id del deck mostrado cuando la URL no trae #hash",
    "decks.<deckId>": {
      "_url": "Se selecciona con el hash de la URL: https://host/#<deckId>",
      "course": "object · metadata (title, shortTitle, subtitle, institution, term)",
      "theme": "object · flags visuales (accent, showProgressDots, ...)",
      "slides[]": {
        "id": "string · clave única; debe coincidir con src/slides/index.js y con el ## anchor en content.md",
        "label": "string · texto en tooltips/dots",
        "props": "object opcional · pasado como props al componente"
      }
    },
    "pipelines.<id>": {
      "module": "string · nombre del módulo en dsp_pipelines/pipelines/",
      "input": "string · archivo en dsp_pipelines/inputs/",
      "params": "object · kwargs serializables pasados a run()",
      "outputs": {
        "audio": "object · { logical_name: 'archivo_destino_en_public.wav' }",
        "images": "object · { logical_name: 'archivo_destino_en_public.png' }"
      }
    }
  }
}
